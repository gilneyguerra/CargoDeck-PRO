# Supabase Configuration
# Get these values from your Supabase project dashboard at https://supabase.com

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# OpenCode Zen — Multi-LLM Router para Extração de Manifestos
# Documentação: https://opencode.ai/docs/pt-br/zen/
#
# IMPORTANTE: NÃO use o prefixo VITE_ aqui. A chave é lida APENAS pelo
# proxy serverless `api/llm-zen.ts` (server-side) — nunca chega ao bundle
# do client. Variáveis com prefixo VITE_* são injetadas no JS do browser
# pelo Vite, o que expõe a chave para qualquer pessoa via DevTools.
OPENCODE_ZEN_KEY=sua-chave-opencode-zen-aqui
# (opcional) Sobrescreve o endpoint upstream — default:
# https://opencode.ai/zen/v1/chat/completions
OPENCODE_ZEN_ENDPOINT=
